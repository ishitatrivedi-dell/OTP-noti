# Email Configuration for Nodemailer
# For Gmail, you need to:
# 1. Enable 2-factor authentication on your Google Account
# 2. Go to Google Account settings > Security > App passwords
# 3. Generate a new app password for "Mail"
# 4. Use the app password below (not your regular password)

# Your Gmail address
EMAIL_USER=your-email@gmail.com

# Your Gmail App Password (16 characters, generated from Google Account settings)
EMAIL_PASS=your-app-password

# Optional: Custom "from" email address
EMAIL_FROM="Transparent Backend Visualizer" <noreply@tbv.com>

# Server Configuration
PORT=5001

# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017/transparent-backend-visualizer
